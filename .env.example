# Copy this file to ".env" and fill in your real values.
# (Never commit the real .env — it holds secrets.)

# A long random string used to sign login sessions. Make one up.
SECRET_KEY=change-me-to-any-long-random-string

# From Google Cloud Console → Credentials → OAuth client ID (Web application)
GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret-here

